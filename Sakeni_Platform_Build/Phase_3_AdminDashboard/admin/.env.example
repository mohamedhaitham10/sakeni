# SAKENI PLATFORM ENVIRONMENT VARIABLES
# Duplicate this file to '.env.local' and securely insert your keys.

# ==========================================
# 1. SUPABASE (Database / Auth / Edge Functions)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-api-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"          # DO NOT expose this to the browser!

# ==========================================
# 2. STRIPE (Landlord Subscriptions & Billing)
# ==========================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_BASIC_PRICE_ID="price_..."
STRIPE_FEATURED_PRICE_ID="price_..."

# ==========================================
# 3. OPENAI (Supabase AI Recommendations)
# ==========================================
OPENAI_API_KEY="sk-..."

# ==========================================
# 4. RESEND (Transactional Emails)
# ==========================================
RESEND_API_KEY="re_..."

# ==========================================
# 5. FIREBASE (Push Notifications / Admin Broadcasts)
# ==========================================
FIREBASE_SERVER_KEY="AAAA..."
